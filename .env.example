# Local development with `dotnet run` (postgres exposed on host port 5432)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=bareq_alnaqool;Username=postgres;Password=postgres

# JWT (required in production — use a long random secret, 32+ characters)
Jwt__Key=BareqAlNaqoolDevSecretKeyChangeInProduction!
Jwt__Issuer=BareqAlNaqool.Api
Jwt__Audience=BareqAlNaqool.Clients
Jwt__ExpiryMinutes=1440

# Local dev only — mobile API migrates and seeds on startup
Database__MigrateOnStartup=true
Database__SeedOnStartup=true

# Production: migrations run automatically on deploy. Do not set Database__SeedOnStartup.

# CORS — comma-separated browser origins (leave empty for mobile-only APIs)
# Cors__AllowedOrigins=https://admin.example.com,https://app.example.com

# Mobile API only — proxy document downloads from admin when files are stored on the admin service.
# Required on Railway when Admin and Mobile API run as separate containers.
# Storage__AdminFilesBaseUrl=https://al-naqool-admin-backend-stage.up.railway.app
# Local dev (mobile API -> admin API):
# Storage__AdminFilesBaseUrl=http://localhost:5001

# Railway production (same pattern as Midank WebApi):
# ConnectionStrings__DefaultConnection=${{ Postgres.DATABASE_URL }}
# Jwt__Key=<long-random-secret-32+chars>
# Jwt__Issuer=BareqAlNaqool.Api
# Jwt__Audience=BareqAlNaqool.Clients
# Cors__AllowedOrigins=https://${{your-frontend.RAILWAY_PUBLIC_DOMAIN}}
# PORT is set automatically by Railway
